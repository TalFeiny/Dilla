# Stripe Configuration
# Get these from https://dashboard.stripe.com/apikeys

# ── Backend (Railway) ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ── Frontend (Vercel) ─────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY
NEXT_PUBLIC_STRIPE_PRICE_ID=price_YOUR_MONTHLY_PRICE_ID

# ── How to get the webhook secret ─────────────────────────────────
# 1. Go to https://dashboard.stripe.com/webhooks
# 2. Add endpoint: https://YOUR_RAILWAY_URL/api/stripe/webhooks
# 3. Select events: checkout.session.completed, customer.subscription.*,
#    invoice.payment_succeeded, invoice.payment_failed
# 4. Copy the signing secret (whsec_...)

# ── Local development ─────────────────────────────────────────────
# stripe listen --forward-to localhost:8000/api/stripe/webhooks